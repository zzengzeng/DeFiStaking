# 复制为 frontend/.env.local 后填入真实值（不要提交 .env.local）
# Next 只会把以 NEXT_PUBLIC_ 开头的变量打进浏览器端 bundle。

# --- 合约地址（与当前 Sepolia 部署一致）---
NEXT_PUBLIC_DUAL_STAKING_ADDRESS=0xYourDualPoolStaking
NEXT_PUBLIC_TOKEN_A_ADDRESS=0xYourTokenA
NEXT_PUBLIC_TOKEN_B_ADDRESS=0xYourTokenB

# --- RPC（读链 + 服务端 timelock 索引用）---
NEXT_PUBLIC_RPC_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# --- 可选：从 staking 部署区块开始扫日志（治理面板 timelock 索引更准确）---
NEXT_PUBLIC_STAKING_DEPLOY_BLOCK=0
